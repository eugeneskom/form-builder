DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-me-to-a-long-random-string"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Optional: OpenAI API key for AI-powered field generation
# If not set, the app uses a rule-based parser instead
OPENAI_API_KEY="your-openai-api-key"

# For Vercel/Production deployment:
# Replace DATABASE_URL with your cloud database (PostgreSQL, MySQL, etc)
# Example formats:
# DATABASE_URL="postgresql://user:password@host:5432/database"
# DATABASE_URL="mysql://user:password@host:3306/database"
# See docs/VERCEL_DEPLOYMENT.md for more information
